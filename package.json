{
  "name": "cc-byok",
  "version": "0.3.2",
  "description": "BYOK provider and gateway launcher for coding agents",
  "type": "module",
  "bin": {
    "cc-byok": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/*.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm test && npm run build",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --pool=threads",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20.17"
  },
  "keywords": [
    "claude-code",
    "codex",
    "opencode",
    "openrouter",
    "byok",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "8.5.2",
    "@napi-rs/keyring": "1.3.0",
    "commander": "14.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
